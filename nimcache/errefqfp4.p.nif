(.nif27)
(.vendor "Nifler")
(.dialect "nim-parsed")
(stmts@,3,../nimony-js/lib/std/errorcodes/errorcodes.nim
 (type@D,1 ErrorCode~B x . .
  (enum@2 .
   (efld~B,1 Success . . . .)
   (efld~B,2 OverflowError . . . .)
   (efld~B,3 Failure . . . .)
   (efld~B,4 BugError . . . .)
   (efld~B,5 IndexError . . . .)
   (efld~B,6 RangeError . . . .)
   (efld~B,7 OverlapError . . . .)
   (efld~B,8 SyntaxError . . . .)
   (efld~B,9 OutOfMemError . . . .)
   (efld~B,A DiskFullError . . . .)
   (efld~B,B StackOverflow . . . .)
   (efld~B,C IOError . . . .)
   (efld~B,D ValueError . . . .)
   (efld~B,E KeyError . . . .)
   (efld~B,F EndOfStreamError . . . .)
   (efld~B,G SkipError . . . .)
   (efld~B,H FullError . . . .)
   (efld~B,I EmptyError . . . .)
   (efld~B,J BusyError . . . .)
   (efld~B,K DeadResource . . . .)
   (efld~B,L ResourceExhaustedError . . . .)
   (efld~B,M DescriptorExhaustedError . . . .)
   (efld~B,N PermissionDenied . . . .)
   (efld~B,O RetryError . . . .)
   (efld~B,P TimeoutError . . . .)
   (efld~B,Q InterruptedError . . . .)
   (efld~B,R DeadlockError . . . .)
   (efld~B,S LockedError . . . .)
   (efld~B,T FormatMismatch . . . .)
   (efld~B,U AlreadyConnected . . . .)
   (efld~B,V AddressNotAvailable . . . .)
   (efld~B,W AddressFamilyUnsupported . . . .)
   (efld~B,X BadOperation . . . .)
   (efld~B,Y AbortedOperation . . . .)
   (efld~B,Z UnimplementedOperation . . . .)
   (efld~B,a AlreadyInProgress . . . .)
   (efld~B,b NameTooLong . . . .)
   (efld~B,c NameExists . . . .)
   (efld~B,d NameNotFound . . . .)
   (efld~B,e ContentTooLong . . . .)
   (efld~B,f BadDescriptor . . . .)
   (efld~B,g BadExecutable . . . .)
   (efld~B,h BadLink . . . .)
   (efld~B,i BadProtocol . . . .)
   (efld~B,j ProtocolError . . . .)
   (efld~B,k ReadonlyProtection . . . .)
   (efld~B,l SegFault . . . .)
   (efld~B,m DiskCorruption . . . .)
   (efld~B,n Disconnected . . . .)
   (efld~B,o RefusedConnection . . . .)
   (efld~B,p UnreachableHost . . . .)
   (efld~B,q UnrecoverableState . . . .)
   (efld~B,r AuthenticationRequired . . . .)
   (efld~B,s RedirectError . . . .)
   (efld~B,t Reserved1 . . . .)
   (efld~B,u Reserved2 . . . .)
   (efld~B,v Reserved3 . . . .)
   (efld~B,w Reserved4 . . . .)
   (efld~B,x Reserved5 . . . .)
   (efld~B,y Reserved6 . . . .)
   (efld~B,z Reserved7 . . . .)
   (efld~B,10 Reserved8 . . . .)
   (efld~B,11 Reserved9 . . . .))))